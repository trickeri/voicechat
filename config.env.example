# Optional overrides for the voicechat daemon (export these in the systemd unit or shell).
# voicechat reads plain env vars; there is no window/config UI by design.

# whispermodel endpoint (default shown):
#WHISPER_HTTP_URL=http://127.0.0.1:48450/inference

# ydotool socket (default shown; ydotoold must be running):
#YDOTOOL_SOCKET=/run/user/1000/.ydotool_socket

# Default paste shortcut (default ctrl+v — works in most apps). Combos: ctrl+v,
# ctrl+shift+v, shift+insert, etc. (modifiers: ctrl/shift/alt/super; key: a-z or insert).
# Used as the default combo for `paste` rules that don't specify their own.
#VOICECHAT_PASTE_KEY=ctrl+v

# Per-application routing rules file (default ~/.config/voicechat/rules.conf). Each line is
# `pattern  mode  [combo]` where mode is paste / clipboard / emit. Copy rules.conf.example to
# get started. Re-read each dictation; needs VOICECHAT_ACTIVE_WINDOW_FILE populated.
#VOICECHAT_RULES_FILE=$HOME/.config/voicechat/rules.conf

# Unix socket every transcript is broadcast on, as one JSON line {"text","app","mode","ts"}.
# Apps connect and read to consume voicechat output directly (the basis for `emit` mode).
#VOICECHAT_SOCKET=$XDG_RUNTIME_DIR/voicechat.sock

# Legacy per-app paste overrides: ;-separated app-substring=combo. Only used when no rules
# file exists. Prefer the rules file above.
#VOICECHAT_PASTE_RULES=ghostty=ctrl+shift+v;kitty=ctrl+shift+v

# Let any key (not just the push-to-talk hotkey) finish a recording. On by default; needs
# read access to /dev/input (the `input` group). Set 0/false/off to require the hotkey.
#VOICECHAT_ANYKEY_STOP=0

# Spoken filler words stripped from dictation before pasting (like Win+H voice typing). On by
# default with the list below; matched whole-word, case-insensitive, ignoring punctuation. The
# raw STT transcript on the bus is untouched. Comma/space-separated; set EMPTY to disable.
#VOICECHAT_FILLERS=um umm uh uhm erm er hmm

# Notification sounds (played via pw-play) — ENABLED by default, pointing at the start/stop
# sounds shipped in the repo's sounds/ directory. Replace those files with your own audio to
# change them, point these at any other files, or comment both lines out (unset = silent).
VOICECHAT_SOUND_START=$HOME/programming/voicechat/sounds/PushToTalkStartSFX.mp3
VOICECHAT_SOUND_STOP=$HOME/programming/voicechat/sounds/PushToTalkStopSFX.mp3
