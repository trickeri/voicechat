# Optional overrides for the voicechat daemon (export these in the systemd unit or shell).
# voicechat reads plain env vars; there is no window/config UI by design.

# whispervulkan endpoint (default shown):
#WHISPER_HTTP_URL=http://127.0.0.1:48450/inference

# ydotool socket (default shown; ydotoold must be running):
#YDOTOOL_SOCKET=/run/user/1000/.ydotool_socket

# Notification sounds (played via pw-play). Point at your own files; unset = silent.
#VOICECHAT_SOUND_START=%h/.config/voicechat/start.wav
#VOICECHAT_SOUND_STOP=%h/.config/voicechat/stop.wav
